@model List<FinalSem2Project.Models.ZerodhaAccount>
@{ ViewData["Title"] = "Zerodha Accounts"; }

<div style="max-width:620px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
        <h2 style="font-family:var(--font-head);font-size:18px;font-weight:700;margin:0">
            <i class="fas fa-key" style="color:var(--accent);margin-right:8px"></i>Zerodha Accounts
        </h2>
        <a href="/Kite/AddAccount" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Account
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card" style="text-align:center;padding:48px">
            <i class="fas fa-key" style="font-size:36px;color:var(--text-muted);margin-bottom:16px;display:block"></i>
            <h4>No accounts added yet</h4>
            <p style="color:var(--text-secondary)">Add your Zerodha API keys to connect your portfolio.</p>
            <a href="/Kite/AddAccount" class="btn btn-primary" style="margin-top:8px">
                <i class="fas fa-plus"></i> Add Account
            </a>
        </div>
    }
    else
    {
        @foreach (var a in Model)
        {
            <div class="card" style="margin-bottom:14px">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
                    <div style="display:flex;align-items:center;gap:14px">
                        <div style="width:42px;height:42px;background:var(--accent-dim);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--accent);font-size:18px;flex-shrink:0">
                            <i class="fas fa-key"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px">@a.Nickname</div>
                            <div style="font-size:12px;color:var(--text-muted);margin-top:2px;font-family:monospace">
                                @(a.ApiKey.Length > 8 ? a.ApiKey[..8] + "••••" : a.ApiKey)
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;gap:8px">
                        <a href="/Kite/EditAccount/@a.Id" class="btn btn-ghost" style="padding:7px 14px;font-size:12px">
                            <i class="fas fa-pencil"></i> Edit
                        </a>
                        <form asp-action="DeleteAccount" asp-controller="Kite" method="post" style="margin:0"
                              onsubmit="return confirm('Remove @a.Nickname? This cannot be undone.')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@a.Id" />
                            <button type="submit" class="btn btn-danger" style="padding:7px 14px;font-size:12px">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        <div style="margin-top:8px">
            <a href="/Kite/Connect" class="btn btn-ghost" style="font-size:13px">
                <i class="fas fa-plug"></i> Manage Connections
            </a>
        </div>
    }
</div>