@model List<FinalSem2Project.Models.KiteAccountStatusModel>
@{ ViewData["Title"] = "Connect Zerodha"; }

<div style="max-width:580px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
        <h2 style="font-family:var(--font-head);font-size:18px;font-weight:700;margin:0">Zerodha Connections</h2>
        <a href="/Kite/ZerodhaSettings" class="btn btn-ghost" style="font-size:12px">
            <i class="fas fa-gear"></i> Manage Keys
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card" style="text-align:center;padding:48px">
            <i class="fas fa-plug" style="font-size:36px;color:var(--text-muted);margin-bottom:16px;display:block"></i>
            <h4>No accounts configured</h4>
            <p style="color:var(--text-secondary)">Add your Zerodha API keys first to connect.</p>
            <a href="/Kite/ZerodhaSettings" class="btn btn-primary" style="margin-top:8px">
                <i class="fas fa-key"></i> Add Account
            </a>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="card" style="margin-bottom:14px;border-color:@(item.IsConnected ? "rgba(110,231,183,0.3)" : "var(--border)")">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px">
                    <div style="display:flex;align-items:center;gap:14px">
                        <div style="width:44px;height:44px;background:@(item.IsConnected ? "var(--green-dim)" : "var(--bg-elevated)");border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;color:@(item.IsConnected ? "var(--accent)" : "var(--text-muted)");flex-shrink:0">
                            <i class="fas fa-@(item.IsConnected ? "circle-check" : "plug")"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:14px">@item.Account.Nickname</div>
                            <div style="font-size:12px;color:@(item.IsConnected ? "var(--accent)" : "var(--text-muted)");margin-top:2px">
                                @(item.IsConnected ? "Connected — portfolio syncing" : "Not connected")
                            </div>
                        </div>
                    </div>

                    @if (item.IsConnected)
                    {
                        <form asp-action="Disconnect" asp-controller="Kite" method="post" style="margin:0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="accountId" value="@item.Account.Id" />
                            <button type="submit" class="btn btn-danger" style="font-size:12px;padding:7px 14px">
                                <i class="fas fa-plug-circle-xmark"></i> Disconnect
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="@item.LoginUrl" class="btn btn-primary" style="font-size:12px;padding:7px 14px">
                            <i class="fas fa-plug"></i> Connect
                        </a>
                    }
                </div>
            </div>
        }

        <div class="card" style="border-color:rgba(96,165,250,0.15);margin-top:8px">
            <div style="display:flex;gap:14px;align-items:flex-start">
                <i class="fas fa-shield-halved" style="color:#60a5fa;font-size:18px;margin-top:2px;flex-shrink:0"></i>
                <div style="font-size:12px;color:var(--text-secondary);line-height:1.7">
                    Your credentials are <strong style="color:var(--text-primary)">never stored</strong> by us beyond your API keys.
                    OAuth tokens are session-only and expire daily.
                </div>
            </div>
        </div>
    }
</div>