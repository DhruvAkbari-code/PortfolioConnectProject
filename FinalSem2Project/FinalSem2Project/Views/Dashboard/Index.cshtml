@model FinalSem2Project.Models.MultiPortfolioViewModel
@{ ViewData["Title"] = "Dashboard"; }

<!-- Combined stat cards across all accounts -->
<div class="stat-grid">
    <div class="stat-card blue">
        <div class="stat-label">Total Investment</div>
        <div class="stat-value">₹@Model.TotalInvestment.ToString("N0")</div>
        <div class="stat-badge up"><i class="fas fa-wallet"></i> All Accounts</div>
    </div>
    <div class="stat-card green">
        <div class="stat-label">Current Value</div>
        <div class="stat-value">₹@Model.TotalValue.ToString("N0")</div>
        <div class="stat-badge up"><i class="fas fa-arrow-trend-up"></i> Live Value</div>
    </div>
    <div class="stat-card @(Model.TotalProfitLoss >= 0 ? "green" : "red")">
        <div class="stat-label">Total P&L</div>
        <div class="stat-value @(Model.TotalProfitLoss >= 0 ? "positive" : "negative")">
            @(Model.TotalProfitLoss >= 0 ? "+" : "")₹@Math.Abs(Model.TotalProfitLoss).ToString("N0")
        </div>
        <div class="stat-badge @(Model.TotalProfitLoss >= 0 ? "up" : "down")">
            <i class="fas fa-@(Model.TotalProfitLoss >= 0 ? "arrow-up" : "arrow-down")"></i> Unrealised P&L
        </div>
    </div>
    <div class="stat-card @(Model.TotalPnlPercentage >= 0 ? "green" : "red")">
        <div class="stat-label">Returns</div>
        <div class="stat-value @(Model.TotalPnlPercentage >= 0 ? "positive" : "negative")">
            @(Model.TotalPnlPercentage >= 0 ? "+" : "")@Model.TotalPnlPercentage.ToString("N2")%
        </div>
        <div class="stat-badge @(Model.TotalPnlPercentage >= 0 ? "up" : "down")">
            <i class="fas fa-percent"></i> Overall
        </div>
    </div>
</div>

@if (!Model.Accounts.Any())
{
    <div class="card" style="text-align:center;padding:48px">
        <i class="fas fa-key" style="font-size:36px;color:var(--text-muted);margin-bottom:16px;display:block"></i>
        <h4>No Zerodha accounts configured</h4>
        <p style="color:var(--text-secondary)">Add your API keys and connect to see your portfolio.</p>
        <a href="/Kite/ZerodhaSettings" class="btn btn-primary" style="margin-top:8px">
            <i class="fas fa-key"></i> Add Account
        </a>
    </div>
}
else
{
    <!-- Tab strip -->
    <div style="display:flex;gap:0;margin-bottom:18px;border-bottom:1px solid var(--border)">
        @for (int i = 0; i < Model.Accounts.Count; i++)
        {
            var acc = Model.Accounts[i];
            <button id="tab-@i" onclick="showTab(@i)"
                    style="background:none;border:none;border-bottom:2px solid @(i == 0 ? "var(--accent)" : "transparent");padding:10px 20px;font-size:13px;font-weight:600;color:@(i == 0 ? "var(--accent)" : "var(--text-secondary)");cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:8px">
                @acc.Nickname
                @if (acc.IsConnected)
                {
                    <span style="width:7px;height:7px;background:var(--accent);border-radius:50%;display:inline-block"></span>
                }
                else
                {
                    <span style="width:7px;height:7px;background:var(--text-muted);border-radius:50%;display:inline-block"></span>
                }
            </button>
        }
    </div>

    <!-- Tab panels -->
    @for (int i = 0; i < Model.Accounts.Count; i++)
    {
        var acc = Model.Accounts[i];
        <div id="panel-@i" style="display:@(i == 0 ? "block" : "none")">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">
                        <i class="fas fa-briefcase" style="color:var(--accent);margin-right:8px"></i>
                        @acc.Nickname
                        @if (acc.Holdings.Any())
                        {
                            <span style="color:var(--text-muted);font-weight:400;font-size:13px"> (@acc.Holdings.Count holdings)</span>
                        }
                    </span>
                    <div style="display:flex;gap:10px;align-items:center">
                        @if (acc.IsConnected)
                        {
                            <span class="badge badge-green"><i class="fas fa-circle" style="font-size:7px"></i> Connected</span>
                            <form asp-action="Disconnect" asp-controller="Kite" method="post" style="margin:0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accountId" value="@acc.AccountId" />
                                <button type="submit" style="background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:12px;padding:0">
                                    <i class="fas fa-plug-circle-xmark"></i> Disconnect
                                </button>
                            </form>
                        }
                        else
                        {
                            <a href="/Kite/Connect" class="badge badge-amber" style="cursor:pointer">
                                <i class="fas fa-plug"></i> Connect
                            </a>
                        }
                    </div>
                </div>

                @if (acc.IsConnected && acc.Holdings.Any())
                {
                    <!-- Per-account mini stats -->
                    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:16px 0;border-bottom:1px solid var(--border);margin-bottom:16px">
                        <div>
                            <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">Invested</div>
                            <div style="font-size:15px;font-weight:600;margin-top:3px">₹@acc.TotalInvestment.ToString("N0")</div>
                        </div>
                        <div>
                            <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">Current</div>
                            <div style="font-size:15px;font-weight:600;margin-top:3px">₹@acc.TotalValue.ToString("N0")</div>
                        </div>
                        <div>
                            <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">P&L</div>
                            <div style="font-size:15px;font-weight:600;margin-top:3px;color:@(acc.TotalProfitLoss >= 0 ? "var(--accent)" : "var(--red)")">
                                @(acc.TotalProfitLoss >= 0 ? "+" : "")₹@Math.Abs(acc.TotalProfitLoss).ToString("N0")
                                <span style="font-size:12px;font-weight:400">
                                    (@(acc.TotalPnlPercentage >= 0 ? "+" : "")@acc.TotalPnlPercentage.ToString("N2")%)
                                </span>
                            </div>
                        </div>
                    </div>

                    <div style="overflow-x:auto">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Symbol</th>
                                    <th>Exchange</th>
                                    <th>Qty</th>
                                    <th>Avg Price</th>
                                    <th>LTP</th>
                                    <th>Invested</th>
                                    <th>Curr. Value</th>
                                    <th>P&L</th>
                                    <th>P&L %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in acc.Holdings)
                                {
                                    var profit   = ((decimal)h.LastPrice - (decimal)h.AveragePrice) * h.Quantity;
                                    var pct      = h.AveragePrice > 0 ? ((h.LastPrice - h.AveragePrice) / h.AveragePrice) * 100 : 0;
                                    var initials = h.TradingSymbol?.Length >= 2 ? h.TradingSymbol[..2] : h.TradingSymbol ?? "—";
                                    <tr>
                                        <td>
                                            <div class="symbol-cell">
                                                <div class="symbol-icon">@initials</div>
                                                <div class="symbol-name">
                                                    <a href="/Stock/@h.TradingSymbol" style="color:inherit;text-decoration:none;font-weight:500">
                                                        @h.TradingSymbol
                                                    </a>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge badge-blue">@(h.Exchange ?? "NSE")</span></td>
                                        <td class="text-primary-val">@h.Quantity</td>
                                        <td class="text-primary-val">₹@h.AveragePrice.ToString("N2")</td>
                                        <td class="text-primary-val">₹@h.LastPrice.ToString("N2")</td>
                                        <td>₹@(((decimal)h.AveragePrice * h.Quantity).ToString("N0"))</td>
                                        <td>₹@(((decimal)h.LastPrice * h.Quantity).ToString("N0"))</td>
                                        <td class="@(profit >= 0 ? "badge-up" : "badge-down")">
                                            @(profit >= 0 ? "+" : "")₹@profit.ToString("N2")
                                        </td>
                                        <td>
                                            <span class="badge @(pct >= 0 ? "badge-green" : "badge-red")">
                                                @(pct >= 0 ? "▲" : "▼") @Math.Abs(pct).ToString("N2")%
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="fas fa-@(acc.IsConnected ? "chart-pie" : "plug")"></i>
                        <h4>@(acc.IsConnected ? "No holdings in this account" : "Not connected")</h4>
                        <p>@(acc.IsConnected ? "This account has no holdings yet." : "Connect this account via Zerodha OAuth to load its portfolio.")</p>
                        @if (!acc.IsConnected)
                        {
                            <a href="/Kite/Connect" class="btn btn-primary">
                                <i class="fas fa-plug"></i> Connect Accounts
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@section Scripts {
<script>
function showTab(idx) {
    document.querySelectorAll('[id^="panel-"]').forEach(p => p.style.display = 'none');
    document.querySelectorAll('[id^="tab-"]').forEach(b => {
        b.style.color = 'var(--text-secondary)';
        b.style.borderBottomColor = 'transparent';
    });
    document.getElementById('panel-' + idx).style.display = 'block';
    const btn = document.getElementById('tab-' + idx);
    btn.style.color = 'var(--accent)';
    btn.style.borderBottomColor = 'var(--accent)';
}
</script>
}