@model FinalSem2Project.Models.User
@{
    ViewData["Title"] = "Profile & Settings";

    var initials = string.IsNullOrEmpty(Model.FullName) ? "U"
                      : string.Concat(Model.FullName.Split(' ').Take(2).Select(w => w[0])).ToUpper();
    var hasAvatar = !string.IsNullOrEmpty(Model.AvatarUrl);
    var memberSince = Model.CreatedAt.ToString("MMMM yyyy");
    var lastLogin = Model.LastLoginAt.HasValue
                      ? Model.LastLoginAt.Value.ToString("dd MMM yyyy, HH:mm") : "—";
    var hasZerodhaKey = !string.IsNullOrEmpty(Model.ZerodhaApiKey);
    var maskedKey = hasZerodhaKey
        ? Model.ZerodhaApiKey!.Substring(0, Math.Min(4, Model.ZerodhaApiKey.Length)) + "••••••••"
        : null;
}

@if (TempData["SuccessMessage"] != null)
{
    <div style="margin-bottom:16px;padding:12px 16px;background:rgba(0,160,90,0.1);
        border:1px solid rgba(0,160,90,0.3);border-radius:8px;
        color:var(--green);font-size:13px">
        <i class="fas fa-circle-check"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div style="margin-bottom:16px;padding:12px 16px;background:rgba(200,40,40,0.08);
        border:1px solid rgba(200,40,40,0.25);border-radius:8px;
        color:var(--red);font-size:13px">
        <i class="fas fa-circle-exclamation"></i> @TempData["ErrorMessage"]
    </div>
}

<div style="display:grid;grid-template-columns:320px 1fr;gap:24px;align-items:start">

    @* ── Left Column: Avatar + Stats ── *@
    <div style="display:flex;flex-direction:column;gap:16px">

        @* Profile Card *@
        <div class="card" style="padding:28px;text-align:center">

            <div style="position:relative;display:inline-block;margin-bottom:16px">
                @if (hasAvatar)
                {
                    <img src="@Model.AvatarUrl" alt="Avatar"
                         style="width:90px;height:90px;border-radius:50%;object-fit:cover;
                    border:3px solid var(--border)" />
                }
                else
                {
                    <div style="width:90px;height:90px;border-radius:50%;
                        background:var(--accent-dim);border:1px solid rgba(110,231,183,0.2);
                        color:var(--accent);font-size:28px;font-weight:500;
                        display:flex;align-items:center;justify-content:center;margin:0 auto">
                        @initials
                    </div>
                }
            </div>

            <div style="font-size:18px;font-weight:500;margin-bottom:4px;color:var(--text-primary)">@Model.FullName</div>
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:12px">@Model.Email</div>

            <div style="display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:16px">
                @if (Model.IsPremium)
                {
                    <span style="font-size:11px;padding:3px 10px;border-radius:20px;
                        background:rgba(186,117,23,0.12);color:#BA7517;font-weight:500">
                        <i class="fas fa-crown" style="font-size:10px"></i> Premium
                    </span>
                }
                @if (Model.EmailVerified)
                {
                    <span style="font-size:11px;padding:3px 10px;border-radius:20px;
                        background:var(--green-dim);color:var(--green);font-weight:500">
                        <i class="fas fa-circle-check" style="font-size:10px"></i> Verified
                    </span>
                }
                @if (!string.IsNullOrEmpty(Model.GoogleId))
                {
                    <span style="font-size:11px;padding:3px 10px;border-radius:20px;
                        background:rgba(56,138,221,0.1);color:#60a5fa;font-weight:500">
                        <i class="fab fa-google" style="font-size:10px"></i> Google
                    </span>
                }
                @if (hasZerodhaKey)
                {
                    <span style="font-size:11px;padding:3px 10px;border-radius:20px;
                        background:var(--accent-dim);color:var(--accent);font-weight:500">
                        <i class="fas fa-link" style="font-size:10px"></i> Zerodha
                    </span>
                }
            </div>

            <div style="border-top:1px solid var(--border);padding-top:16px;
                display:flex;flex-direction:column;gap:8px;text-align:left">
                <div style="display:flex;justify-content:space-between;font-size:12px">
                    <span style="color:var(--text-secondary)">Member since</span>
                    <span style="color:var(--text-primary)">@memberSince</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px">
                    <span style="color:var(--text-secondary)">Last login</span>
                    <span style="color:var(--text-primary)">@lastLogin</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:12px">
                    <span style="color:var(--text-secondary)">Account status</span>
                    <span style="color:@(Model.IsActive ? "var(--green)" : "var(--red)")">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>
        </div>

        @* Stats Card *@
        <div class="card" style="padding:20px">
            <div style="font-size:11px;font-weight:600;margin-bottom:14px;
                color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em">
                Activity
            </div>
            <div style="display:flex;flex-direction:column;gap:12px">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:13px;color:var(--text-secondary)">
                        <i class="fas fa-heart" style="color:var(--red);margin-right:6px;font-size:12px"></i>
                        Watchlist stocks
                    </span>
                    <span style="font-size:16px;font-weight:500;color:var(--text-primary)">@ViewBag.WatchlistCount</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:13px;color:var(--text-secondary)">
                        <i class="fas fa-bullseye" style="color:var(--amber);margin-right:6px;font-size:12px"></i>
                        Total targets
                    </span>
                    <span style="font-size:16px;font-weight:500;color:var(--text-primary)">@ViewBag.TargetCount</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:13px;color:var(--text-secondary)">
                        <i class="fas fa-circle-dot" style="color:var(--green);margin-right:6px;font-size:12px"></i>
                        Active targets
                    </span>
                    <span style="font-size:16px;font-weight:500;color:var(--green)">@ViewBag.ActiveTargets</span>
                </div>
            </div>
        </div>

    </div>

    @* ── Right Column: Edit Forms ── *@
    <div style="display:flex;flex-direction:column;gap:20px">

        @* ── Profile Information ── *@
        <div class="card">
            <div class="card-header">
                <span class="card-title">
                    <i class="fas fa-user" style="margin-right:8px;color:var(--text-secondary)"></i>
                    Profile Information
                </span>
            </div>
            <div style="padding:24px">
                <form method="post" action="/Profile/UpdateInfo" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
                        <div class="form-group" style="margin:0">
                            <label class="form-label">Full Name</label>
                            <input type="text" name="fullName" class="form-input"
                                   value="@Model.FullName" required />
                        </div>
                        <div class="form-group" style="margin:0">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-input"
                                   value="@Model.Email" disabled
                                   style="opacity:0.5;cursor:not-allowed" />
                            <span style="font-size:11px;color:var(--text-muted)">
                                Email cannot be changed
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Profile Picture</label>
                        <div style="display:flex;align-items:center;gap:16px">
                            @if (hasAvatar)
                            {
                                <img src="@Model.AvatarUrl" alt="Current avatar"
                                     style="width:48px;height:48px;border-radius:50%;object-fit:cover;
                                border:2px solid var(--border)" />
                            }
                            else
                            {
                                <div style="width:48px;height:48px;border-radius:50%;
                                    background:var(--accent-dim);border:1px solid rgba(110,231,183,0.2);
                                    color:var(--accent);font-size:16px;font-weight:500;
                                    display:flex;align-items:center;justify-content:center">
                                    @initials
                                </div>
                            }
                            <div style="flex:1">
                                <input type="file" name="avatarFile" id="avatarFile"
                                       accept=".jpg,.jpeg,.png,.webp"
                                       class="form-input" style="padding:6px" />
                                <span style="font-size:11px;color:var(--text-muted)">
                                    JPG, PNG or WEBP — max 2MB
                                </span>
                            </div>
                        </div>
                    </div>

                    <div style="display:flex;justify-content:flex-end;margin-top:8px">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-floppy-disk"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* ── Change Password ── *@
        <div class="card">
            <div class="card-header">
                <span class="card-title">
                    <i class="fas fa-lock" style="margin-right:8px;color:var(--text-secondary)"></i>
                    Change Password
                </span>
            </div>
            <div style="padding:24px">

                @if (!string.IsNullOrEmpty(Model.GoogleId))
                {
                    <div style="padding:16px;background:rgba(56,138,221,0.07);
                        border:1px solid rgba(56,138,221,0.15);border-radius:var(--radius-md);
                        font-size:13px;color:var(--text-secondary);text-align:center">
                        <i class="fab fa-google" style="margin-right:6px"></i>
                        Your account uses Google login — password change is not available.
                    </div>
                }
                else
                {
                    <form method="post" action="/Profile/ChangePassword">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="form-label">Current Password</label>
                            <div style="position:relative">
                                <input type="password" name="currentPassword" id="currentPwd"
                                       class="form-input" style="padding-right:42px"
                                       placeholder="Enter current password" required />
                                <button type="button" onclick="togglePwd('currentPwd', this)"
                                        style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                                    background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </div>

                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                            <div class="form-group" style="margin:0">
                                <label class="form-label">New Password</label>
                                <div style="position:relative">
                                    <input type="password" name="newPassword" id="newPwd"
                                           class="form-input" style="padding-right:42px"
                                           placeholder="Min 6 characters" required />
                                    <button type="button" onclick="togglePwd('newPwd', this)"
                                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                                        background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="form-group" style="margin:0">
                                <label class="form-label">Confirm New Password</label>
                                <div style="position:relative">
                                    <input type="password" name="confirmPassword" id="confirmPwd"
                                           class="form-input" style="padding-right:42px"
                                           placeholder="Repeat new password" required />
                                    <button type="button" onclick="togglePwd('confirmPwd', this)"
                                            style="position:absolute;right:12px;top:50%;transform:translateY(-50%);
                                        background:none;border:none;cursor:pointer;color:var(--text-muted)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div style="margin-top:14px">
                            <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;
                                text-transform:uppercase;letter-spacing:0.05em">
                                Password strength
                            </div>
                            <div style="display:flex;gap:4px">
                                <div id="str1" style="height:4px;flex:1;border-radius:2px;background:var(--border)"></div>
                                <div id="str2" style="height:4px;flex:1;border-radius:2px;background:var(--border)"></div>
                                <div id="str3" style="height:4px;flex:1;border-radius:2px;background:var(--border)"></div>
                                <div id="str4" style="height:4px;flex:1;border-radius:2px;background:var(--border)"></div>
                            </div>
                            <div id="strLabel" style="font-size:11px;margin-top:5px;color:var(--text-muted)"></div>
                        </div>

                        <div style="display:flex;justify-content:flex-end;margin-top:16px">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-lock"></i> Update Password
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>

        @* ── Account Details ── *@
        <div class="card">
            <div class="card-header">
                <span class="card-title">
                    <i class="fas fa-circle-info" style="margin-right:8px;color:var(--text-secondary)"></i>
                    Account Details
                </span>
            </div>
            <div style="padding:24px">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                    <div style="background:var(--bg-elevated);border:1px solid var(--border);
                        border-radius:var(--radius-md);padding:14px">
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;
                            text-transform:uppercase;letter-spacing:0.05em">
                            Account Type
                        </div>
                        <div style="font-size:14px;font-weight:500;
                            color:@(Model.IsPremium ? "#BA7517" : "var(--text-primary)")">
                            @(Model.IsPremium ? "⭐ Premium" : "Free")
                        </div>
                    </div>
                    @if (Model.IsPremium && Model.SubscriptionEnd.HasValue)
                    {
                        <div style="background:var(--bg-elevated);border:1px solid var(--border);
                            border-radius:var(--radius-md);padding:14px">
                            <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;
                                text-transform:uppercase;letter-spacing:0.05em">
                                Subscription Ends
                            </div>
                            <div style="font-size:14px;font-weight:500;color:#BA7517">
                                @Model.SubscriptionEnd.Value.ToString("dd MMM yyyy")
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fas fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fas fa-eye';
            }
        }

        function confirmRemoveKeys() {
            if (confirm('Remove your Zerodha API keys? Live trading features will be disabled.')) {
                document.getElementById('removeKeysForm').submit();
            }
        }

        document.getElementById('newPwd')?.addEventListener('input', function () {
            const val = this.value;
            const bars = [
                document.getElementById('str1'),
                document.getElementById('str2'),
                document.getElementById('str3'),
                document.getElementById('str4')
            ];
            const label = document.getElementById('strLabel');

            let score = 0;
            if (val.length >= 6) score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const colors = ['#e24b4a', '#e25c1a', '#BA7517', 'var(--green)'];
            const labels = ['Weak', 'Fair', 'Good', 'Strong'];

            bars.forEach((b, i) => {
                b.style.background = i < score ? colors[score - 1] : 'var(--border)';
            });

            label.textContent = score > 0 ? labels[score - 1] : '';
            label.style.color = score > 0 ? colors[score - 1] : 'var(--text-muted)';
        });

        document.getElementById('avatarFile')?.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                document.querySelectorAll('img[alt="Current avatar"], img[alt="Avatar"]')
                    .forEach(img => { img.src = e.target.result; });
            };
            reader.readAsDataURL(file);
        });
    </script>
}