@model List<FinalSem2Project.Controllers.ChatMessage>
@{
    ViewData["Title"] = "AI Stock Assistant";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - var(--topbar-h) - 56px);
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border);
    }

    /* Header */
    .chat-header {
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 14px;
        flex-shrink: 0;
    }

    .chat-header-icon {
        width: 38px;
        height: 38px;
        background: var(--accent-dim);
        border: 1px solid rgba(110, 231, 183, 0.2);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 16px;
        flex-shrink: 0;
    }

    .chat-header-info h2 {
        font-family: var(--font-head);
        font-size: 15px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 2px 0;
    }

    .chat-header-info p {
        font-size: 11px;
        color: var(--text-muted);
        margin: 0;
    }

    .ai-badge {
        margin-left: auto;
        background: var(--accent-dim);
        border: 1px solid rgba(110, 231, 183, 0.2);
        color: var(--accent);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    /* Quick Actions */
    .quick-actions {
        padding: 10px 16px;
        background: var(--bg-elevated);
        border-bottom: 1px solid var(--border);
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        flex-shrink: 0;
    }

    .quick-btn {
        padding: 5px 14px;
        background: var(--bg-card);
        border: 1px solid var(--border-bright);
        border-radius: 20px;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 11px;
        font-family: var(--font-body);
        transition: all 0.2s;
    }

        .quick-btn:hover {
            background: var(--accent-dim);
            border-color: rgba(110, 231, 183, 0.3);
            color: var(--accent);
        }

    /* Messages Area */
    .messages-area {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: var(--bg-base);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

        .messages-area::-webkit-scrollbar {
            width: 4px;
        }

        .messages-area::-webkit-scrollbar-track {
            background: transparent;
        }

        .messages-area::-webkit-scrollbar-thumb {
            background: var(--border-bright);
            border-radius: 2px;
        }

    /* Messages */
    .message {
        display: flex;
        align-items: flex-end;
        gap: 10px;
        animation: msgFadeIn 0.25s ease;
    }

    @@keyframes msgFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
}

@@keyframes typingDot {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
}
    

    .user-message {
        justify-content: flex-end;
    }

    .assistant-message {
        justify-content: flex-start;
    }

    .msg-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 11px;
        flex-shrink: 0;
    }

    .user-message .msg-avatar {
        order: 2;
        background: var(--accent);
        color: #0a0b0f;
    }

    .assistant-message .msg-avatar {
        background: var(--accent-dim);
        border: 1px solid rgba(110, 231, 183, 0.2);
        color: var(--accent);
    }

    .msg-body {
        display: flex;
        flex-direction: column;
        max-width: 68%;
    }

    .user-message .msg-body {
        align-items: flex-end;
    }

    .msg-bubble {
        padding: 10px 15px;
        border-radius: var(--radius-md);
        font-size: 13px;
        line-height: 1.6;
        word-wrap: break-word;
    }

    .user-message .msg-bubble {
        background: var(--accent);
        color: #0a0b0f;
        font-weight: 500;
        border-bottom-right-radius: 4px;
    }

    .assistant-message .msg-bubble {
        background: var(--bg-card);
        color: var(--text-primary);
        border: 1px solid var(--border);
        border-bottom-left-radius: 4px;
    }

    .msg-time {
        font-size: 10px;
        color: var(--text-muted);
        margin-top: 5px;
        padding: 0 2px;
    }

    /* Typing Indicator */
    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 10px 14px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        border-bottom-left-radius: 4px;
        width: fit-content;
    }

        .typing-indicator span {
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: typingDot 1.4s infinite;
            opacity: 0.5;
        }

            .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
            .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

   

    /* Input Area */
    .chat-input-area {
        padding: 14px 18px;
        background: var(--bg-card);
        border-top: 1px solid var(--border);
        display: flex;
        gap: 10px;
        align-items: center;
        flex-shrink: 0;
    }

    .chat-input {
        flex: 1;
        padding: 10px 16px;
        border: 1px solid var(--border);
        border-radius: 24px;
        background: var(--bg-elevated);
        color: var(--text-primary);
        font-size: 13px;
        font-family: var(--font-body);
        resize: none;
        outline: none;
        max-height: 120px;
        transition: border-color 0.2s;
    }

        .chat-input:focus {
            border-color: rgba(110, 231, 183, 0.4);
        }

        .chat-input::placeholder {
            color: var(--text-muted);
        }

    .send-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: var(--accent);
        border: none;
        color: #0a0b0f;
        cursor: pointer;
        font-size: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.2s;
    }

        .send-btn:hover { background: #a7f3d0; }
        .send-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .clear-btn {
        padding: 8px 14px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 24px;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 12px;
        font-family: var(--font-body);
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .clear-btn:hover {
            border-color: rgba(248, 113, 113, 0.3);
            color: var(--red);
        }
</style>

<div class="chat-container">

    <div class="chat-header">
        <div class="chat-header-icon">
            <i class="fas fa-robot"></i>
        </div>
        <div class="chat-header-info">
            <h2>AI Stock Assistant</h2>
            <p>Ask about Indian stocks, market trends, prices &amp; news</p>
        </div>
        <span class="ai-badge">Powered by DeepSeek</span>
    </div>

    <div class="quick-actions">
        <button class="quick-btn" onclick="quickQuestion('What is Reliance share price?')">📈 Reliance Price</button>
        <button class="quick-btn" onclick="quickQuestion('Latest news about TCS')">📰 TCS News</button>
        <button class="quick-btn" onclick="quickQuestion('Analyze Infosys stock trend')">📊 Analyze Infosys</button>
        <button class="quick-btn" onclick="quickQuestion('Nifty 50 performance today')">📉 Nifty 50</button>
        <button class="quick-btn" onclick="quickQuestion('HDFC Bank 52 week high low')">🎯 HDFC Bank Range</button>
    </div>

    <div class="messages-area" id="messagesArea">
        @foreach (var msg in Model)
        {
            <div class="message @(msg.Role == "user" ? "user-message" : "assistant-message")">
                @if (msg.Role == "assistant")
                {
                    <div class="msg-avatar">
                        <i class="fas fa-robot" style="font-size: 12px;"></i>
                    </div>
                }
                <div class="msg-body">
                    <div class="msg-bubble">
                        @Html.Raw(msg.Content.Replace("\n", "<br/>"))
                    </div>
                    <div class="msg-time">@msg.Timestamp.ToString("HH:mm")</div>
                </div>
                @if (msg.Role == "user")
                {
                    <div class="msg-avatar">@ViewBag.UserInitials</div>
                }
            </div>
        }
    </div>

    <div class="chat-input-area">
        <textarea class="chat-input" id="messageInput" placeholder="Ask about stocks, prices, news, trends..." rows="1"></textarea>
        <button class="clear-btn" onclick="clearChat()" title="Clear chat">
            <i class="fas fa-trash-alt"></i>
        </button>
        <button class="send-btn" id="sendButton" onclick="sendMessage()">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
</div>

@section Scripts {
<script>
    let isTyping = false;

    const textarea = document.getElementById('messageInput');
    textarea.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    textarea.addEventListener('keypress', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    async function sendMessage() {
        if (isTyping) return;
        const input = document.getElementById('messageInput');
        const message = input.value.trim();
        if (!message) return;

        addMessage(message, 'user');
        input.value = '';
        input.style.height = 'auto';
        showTypingIndicator();
        isTyping = true;
        document.getElementById('sendButton').disabled = true;

        try {
            const response = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: message })
            });
            const data = await response.json();
            removeTypingIndicator();
            addMessage(data.success ? data.answer : ('Error: ' + (data.error || 'Please try again.')), 'assistant', data.timestamp);
        } catch {
            removeTypingIndicator();
            addMessage('Network error. Please check your connection.', 'assistant');
        } finally {
            isTyping = false;
            document.getElementById('sendButton').disabled = false;
        }
    }

    function addMessage(text, sender, timestamp = null) {
        const area = document.getElementById('messagesArea');
        const div = document.createElement('div');
        div.className = `message ${sender}-message`;

        const time = timestamp || new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const initials = '@ViewBag.UserInitials';

        const avatarHtml = sender === 'assistant'
            ? `<div class="msg-avatar"><i class="fas fa-robot" style="font-size:12px"></i></div>`
            : `<div class="msg-avatar">${initials}</div>`;

        div.innerHTML = `
            ${sender === 'assistant' ? avatarHtml : ''}
            <div class="msg-body">
                <div class="msg-bubble">${escapeHtml(text).replace(/\n/g, '<br/>')}</div>
                <div class="msg-time">${time}</div>
            </div>
            ${sender === 'user' ? avatarHtml : ''}
        `;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
    }

    function showTypingIndicator() {
        const area = document.getElementById('messagesArea');
        const div = document.createElement('div');
        div.className = 'message assistant-message';
        div.id = 'typingIndicator';
        div.innerHTML = `
            <div class="msg-avatar"><i class="fas fa-robot" style="font-size:12px"></i></div>
            <div class="msg-body">
                <div class="typing-indicator"><span></span><span></span><span></span></div>
            </div>
        `;
        area.appendChild(div);
        area.scrollTop = area.scrollHeight;
    }

    function removeTypingIndicator() {
        document.getElementById('typingIndicator')?.remove();
    }

    function quickQuestion(q) {
        document.getElementById('messageInput').value = q;
        sendMessage();
    }

    async function clearChat() {
        if (confirm('Clear the chat history?')) {
            await fetch('/Chat/ClearChat', { method: 'POST' });
            document.getElementById('messagesArea').innerHTML = '';
            addMessage('👋 Chat cleared! Ask me anything about Indian stocks!', 'assistant');
        }
    }

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    window.onload = () => {
        const area = document.getElementById('messagesArea');
        area.scrollTop = area.scrollHeight;
    };
</script>
}